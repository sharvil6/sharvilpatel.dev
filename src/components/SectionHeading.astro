---
interface Props {
  title: string;
  /** Retained for caller compatibility; no longer rendered as a numbered index. */
  index?: string;
  count?: number;
}

const { title, count } = Astro.props;
---

<div class="section-heading">
  <h2>{title}</h2>
  <span class="rule" aria-hidden="true"></span>
  {count !== undefined && <span class="count mono-label">{count}</span>}
</div>

<style>
  .section-heading {
    display: flex;
    align-items: center;
    gap: var(--s3);
    margin-block-end: var(--s4);
  }

  h2 {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: 0;
    color: var(--muted);
    flex: none;
  }

  .rule {
    flex: 1;
    height: 1px;
    background: var(--line);
  }

  .count {
    flex: none;
  }
</style>
