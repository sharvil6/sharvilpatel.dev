---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

// h2/h3 only: h1 is the page title, deeper levels are noise in a margin nav.
const items = Astro.props.headings.filter((h) => h.depth === 2 || h.depth === 3);
const show = items.length >= 2;
---

{
  show && (
    <>
      <nav class="toc no-print" aria-label="Contents" data-toc>
        <p class="mono-label toc-title" aria-hidden="true">
          Contents
        </p>
        <ol>
          {items.map((h) => (
            <li class={h.depth === 3 ? 'sub' : undefined}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ol>
      </nav>

      <details class="toc-sheet no-print">
        <summary class="mono-label">Contents</summary>
        <ol>
          {items.map((h) => (
            <li class={h.depth === 3 ? 'sub' : undefined}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ol>
      </details>
    </>
  )
}

{
  show && (
    <script is:inline>
      // Scroll spy: mark the TOC link for the last heading above the reading
      // line. Pure enhancement — without JS the anchor links still work.
      (() => {
        const toc = document.querySelector('[data-toc]');
        if (!toc) return;
        const links = [...toc.querySelectorAll('a[href^="#"]')];
        const heads = links
          .map((a) => document.getElementById(decodeURIComponent(a.hash.slice(1))))
          .filter(Boolean);
        if (heads.length !== links.length) return;

        let active = null;
        const update = () => {
          const line = innerHeight * 0.25;
          let i = heads.length - 1;
          while (i >= 0 && heads[i].getBoundingClientRect().top > line) i--;
          // Pin the last entry once the page bottoms out, so short final
          // sections can still register as current.
          if (innerHeight + scrollY >= document.documentElement.scrollHeight - 2) {
            i = heads.length - 1;
          }
          const next = i >= 0 ? links[i] : null;
          if (next === active) return;
          if (active) active.removeAttribute('aria-current');
          if (next) next.setAttribute('aria-current', 'true');
          active = next;
        };

        let ticking = false;
        const onScroll = () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            ticking = false;
            update();
          });
        };
        addEventListener('scroll', onScroll, { passive: true });
        addEventListener('resize', onScroll, { passive: true });
        update();
      })();
    </script>
  )
}

<style>
  /* ----- shared list bones (margin nav + mobile sheet) ----- */

  ol {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li + li {
    margin-block-start: 0.45em;
  }

  .sub {
    padding-inline-start: var(--s2);
  }

  /* ----- margin nav: wide viewports only, where the frame leaves room ----- */

  .toc {
    display: none;
  }

  @media (min-width: 64rem) {
    .toc {
      display: block;
      grid-column: 2;
      grid-row: 1;
      position: sticky;
      top: var(--s6);
      align-self: start;
      max-height: calc(100vh - var(--s12));
      overflow-y: auto;
      font-size: var(--text-sm);
      line-height: 1.45;
    }
  }

  .toc-title {
    font-size: var(--text-xs);
    color: var(--faint);
    margin-block-end: var(--s2);
  }

  .toc a {
    color: var(--muted);
    transition: color 0.2s var(--ease-out);
  }

  .toc a:hover {
    color: var(--accent);
  }

  .toc a[aria-current] {
    color: var(--ink);
  }

  /* The mark's closing-period dot lands on the section being read.
     Always occupies space so activation never reflows the text. */
  .toc a::after {
    content: '';
    display: inline-block;
    width: 0.28em;
    height: 0.28em;
    margin-inline-start: 0.14em;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0;
    transform: translateY(0.12em);
    transition:
      opacity 0.25s var(--ease-out),
      transform 0.25s var(--ease-out);
  }

  .toc a[aria-current]::after {
    opacity: 1;
    transform: none;
  }

  /* Hover echoes the mark exactly: the dot appears and hops, even on
     the current entry (this rule wins by source order). */
  .toc a:hover::after {
    opacity: 1;
    transform: translateY(-0.28em);
  }

  /* ----- mobile sheet: a collapsed jump menu at the top of the article ----- */

  .toc-sheet {
    border-block: var(--hairline);
    padding-block: var(--s2);
    margin-block-end: var(--s6);
  }

  @media (min-width: 64rem) {
    .toc-sheet {
      display: none;
    }
  }

  summary {
    list-style: none;
    cursor: pointer;
    width: fit-content;
    -webkit-tap-highlight-color: transparent;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  /* No disclosure triangle: the mark's dot is the affordance. It rests
     like a closing period and hops when the sheet opens. */
  summary::after {
    content: '';
    display: inline-block;
    width: 0.28em;
    height: 0.28em;
    margin-inline-start: 0.14em;
    border-radius: 50%;
    background: var(--accent);
    transition: transform 0.25s var(--ease-out);
  }

  .toc-sheet[open] summary::after {
    transform: translateY(-0.28em);
  }

  .toc-sheet ol {
    margin-block-start: var(--s2);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .toc-sheet a {
    color: var(--accent);
  }
</style>
