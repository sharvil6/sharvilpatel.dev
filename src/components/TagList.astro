---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<ul class="tags mono-label">
  {tags.map((tag) => <li>{tag}</li>)}
</ul>

<style>
  .tags {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0 var(--s2);
    font-size: var(--text-xs);
    color: var(--faint);
  }

  li + li::before {
    content: "·";
    margin-inline-end: var(--s2);
    color: var(--line);
  }
</style>
