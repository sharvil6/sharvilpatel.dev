---
const nav = [
  { href: '/projects', label: 'Projects' },
  { href: '/resume', label: 'Resume' },
  { href: '/blog', label: 'Writing' },
];

const current = Astro.url.pathname;
const isActive = (href: string) => current === href || current.startsWith(href + '/');
---

<header class="pad">
  <a href="/" class="mark" aria-label="Sharvil Patel, home">
    <span aria-hidden="true">SP</span><span class="mark-dot" aria-hidden="true"></span>
  </a>
  <div class="end">
    <nav aria-label="Main">
      <ul>
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['nav-link', { active: isActive(item.href) }]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <button type="button" class="theme-toggle" aria-label="Switch color theme" title="Switch color theme">
      <svg class="icon icon-system" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="13" rx="1.5" />
        <path d="M8 21h8M12 17v4" />
      </svg>
      <svg class="icon icon-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
      </svg>
      <svg class="icon icon-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5z" />
      </svg>
    </button>
  </div>
</header>

<script is:inline>
  document.querySelectorAll('.theme-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const order = ['system', 'light', 'dark'];
      const current = localStorage.getItem('theme') || 'system';
      const next = order[(order.indexOf(current) + 1) % order.length];
      localStorage.setItem('theme', next);
      document.documentElement.dataset.theme = next;
    });
  });
</script>

<style>
  header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--s2) var(--s4);
    padding-block: var(--s4);
  }

  /* identity mark: tight initials + the accent dot as a closing period.
     the dot is the site's recurring motif (status indicator, favicon). */
  .mark {
    display: inline-flex;
    align-items: baseline;
    font-size: 1.2rem;
    font-weight: 660;
    letter-spacing: -0.03em;
    color: var(--ink);
    transition: color 0.2s var(--ease-out);
  }

  .mark-dot {
    width: 0.26em;
    height: 0.26em;
    margin-inline-start: 0.12em;
    border-radius: 50%;
    background: var(--accent);
    transition: transform 0.25s var(--ease-out);
  }

  .mark:hover .mark-dot {
    transform: translateY(-0.28em);
  }

  .end {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 4vw, 2rem);
  }

  nav ul {
    list-style: none;
    padding: 0;
    display: flex;
    gap: clamp(1rem, 4vw, 2rem);
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
    padding-block-end: 2px;
    border-bottom: 1px solid transparent;
    transition: color 0.2s var(--ease-out), border-color 0.2s var(--ease-out);
  }

  .nav-link:hover {
    color: var(--ink);
  }

  .nav-link.active {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }

  /* theme toggle: hidden until JS confirms it can do anything */
  .theme-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: none;
    border: 0;
    color: var(--muted);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.2s var(--ease-out);
  }

  :global(html.js) .theme-toggle {
    display: inline-flex;
  }

  .theme-toggle:hover {
    color: var(--ink);
  }

  .theme-toggle .icon {
    width: 1.1rem;
    height: 1.1rem;
  }

  /* show exactly one icon for the active choice */
  .icon {
    display: none;
  }

  :global(:root:not([data-theme])) .icon-system,
  :global(:root[data-theme='system']) .icon-system,
  :global(:root[data-theme='light']) .icon-light,
  :global(:root[data-theme='dark']) .icon-dark {
    display: block;
  }
</style>
