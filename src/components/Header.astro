---
const nav = [
  { href: '/projects', label: 'Projects' },
  { href: '/resume', label: 'Resume' },
  { href: '/blog', label: 'Writing' },
];

const current = Astro.url.pathname;
const isActive = (href: string) => current === href || current.startsWith(href + '/');
---

<header class="pad">
  <a href="/" class="mark" aria-label="Sharvil Patel, home">
    <span aria-hidden="true">SP</span><span class="mark-dot" aria-hidden="true"></span>
  </a>
  <nav aria-label="Main">
    <ul>
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['nav-link', { active: isActive(item.href) }]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--s2) var(--s4);
    padding-block: var(--s4);
  }

  /* identity mark: tight initials + the accent dot as a closing period.
     the dot is the site's recurring motif (status indicator, favicon). */
  .mark {
    display: inline-flex;
    align-items: baseline;
    font-size: 1.2rem;
    font-weight: 660;
    letter-spacing: -0.03em;
    color: var(--ink);
    transition: color 0.2s var(--ease-out);
  }

  .mark-dot {
    width: 0.26em;
    height: 0.26em;
    margin-inline-start: 0.12em;
    border-radius: 50%;
    background: var(--accent);
    transition: transform 0.25s var(--ease-out);
  }

  .mark:hover .mark-dot {
    transform: translateY(-0.28em);
  }

  ul {
    list-style: none;
    padding: 0;
    display: flex;
    gap: clamp(1rem, 4vw, 2rem);
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
    padding-block-end: 2px;
    border-bottom: 1px solid transparent;
    transition: color 0.2s var(--ease-out), border-color 0.2s var(--ease-out);
  }

  .nav-link:hover {
    color: var(--ink);
  }

  .nav-link.active {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }
</style>
