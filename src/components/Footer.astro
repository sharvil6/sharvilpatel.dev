---
const year = new Date().getFullYear();

const links = [
  { href: 'https://github.com/sharvil6', label: 'GitHub' },
  { href: 'mailto:sharvilpatel95@gmail.com', label: 'Email' },
  { href: '/rss.xml', label: 'RSS' },
];
---

<footer class="pad no-print">
  <ul>
    {
      links.map((link) => (
        <li>
          <a href={link.href}>{link.label}</a>
        </li>
      ))
    }
  </ul>
  <p>&copy; {year} Sharvil Patel &middot; Static and fast, almost no JavaScript</p>
</footer>

<style>
  footer {
    margin-block-start: var(--s8);
    border-top: var(--hairline);
    padding-block: var(--s4);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--s2) var(--s4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
  }

  ul {
    list-style: none;
    padding: 0;
    display: flex;
    gap: var(--s3);
  }

  a {
    transition: color 0.2s var(--ease-out);
  }

  a:hover {
    color: var(--ink);
  }
</style>
