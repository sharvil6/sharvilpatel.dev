---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogType?: 'website' | 'article';
  /** Full <title> override for the home page */
  titleOverride?: string;
}

const { title, description, ogType = 'website', titleOverride } = Astro.props;
const pageTitle = titleOverride ?? `${title} · Sharvil Patel`;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Set the theme before first paint (no flash); also marks JS as available
         so the no-op toggle stays hidden when scripting is off. -->
    <script is:inline>
      (() => {
        const root = document.documentElement;
        root.classList.add('js');
        root.dataset.theme = localStorage.getItem('theme') || 'system';
      })();
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Sharvil Patel" href="/rss.xml" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Sharvil Patel" />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <div class="frame">
      <Header />
      <main id="main">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
