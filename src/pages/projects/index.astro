---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ProjectRow from '../../components/ProjectRow.astro';

const showDrafts = import.meta.env.DEV;
const projects = (await getCollection('projects', ({ data }) => showDrafts || !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Projects" description="Project writeups: what was built, why, and what it cost.">
  <section class="section pad reveal">
    <SectionHeading index="01" title="Projects" count={projects.length} />
    <div class="work">
      {projects.map((project, i) => <ProjectRow project={project} index={i + 1} />)}
    </div>
  </section>
</BaseLayout>

