---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProjectRow from '../components/ProjectRow.astro';

const showDrafts = import.meta.env.DEV;
const featured = (await getCollection('projects', ({ data }) => data.featured && (showDrafts || !data.draft)))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Sharvil Patel"
  titleOverride="Sharvil Patel · Software Engineer"
  description="Software engineer. Project writeups, resume, and occasional articles on building systems."
>
  <section class="hero pad">
    <h1 class="display">Sharvil Patel</h1>
    <p class="lead">
      Problem solver. Currently building an AI orchestration platform on a custom agent harness for Dell.
    </p>
    <p class="status mono-label"><span class="dot" aria-hidden="true"></span>Building, reading, and occasionally writing it down.</p>
    <ul class="contact mono-label">
      <li><a href="mailto:sharvilpatel95@gmail.com">sharvilpatel95@gmail.com</a></li>
      <li><a href="https://github.com/sharvil6">github.com/sharvil6</a></li>
      <li>Austin, TX</li>
    </ul>
  </section>

  <section class="work pad reveal">
    <SectionHeading title="Selected work" count={featured.length} />
    <div class="work-list">
      {featured.map((project, i) => <ProjectRow project={project} index={i + 1} />)}
    </div>
    <p class="all-link"><a href="/projects">All projects &rarr;</a></p>
  </section>

  <section class="about pad reveal">
    <SectionHeading title="About" />
    <div class="prose">
      <p>
        I'm a computer engineer who likes leveraging technology to solve meaningful problems. 
        I am an infinite learner who loves taking on a new challenge. Currently I'm applying AI at Dell - identifying interesting opportunities to accelerate the "product factory".
        I write up side projects that I'm curious about and other things I find interesting here.
      </p>
      <p>
        The best way to evaluate me is the <a href="/projects">project writeups</a> or the
        <a href="/resume">resume</a>.
      </p>
    </div>
  </section>

  <section class="contact-section pad reveal">
    <SectionHeading title="Contact" />
    <p class="contact-lead">Reach me directly:</p>
    <p class="contact-big">
      <a href="mailto:sharvilpatel95@gmail.com">sharvilpatel95@gmail.com</a>
    </p>
  </section>
</BaseLayout>

<style>
  /* rhythm: generous hero, work pulled in close, distinct passes below */
  .hero {
    padding-block: var(--s16) var(--s8);
  }

  .lead {
    margin-block-start: var(--s4);
    font-size: var(--text-lead);
    line-height: 1.3;
    letter-spacing: -0.01em;
    max-width: 28ch;
    text-wrap: balance;
  }

  .status {
    margin-block-start: var(--s4);
    display: flex;
    align-items: center;
    gap: 0.6em;
    color: var(--ink);
  }

  .dot {
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background: var(--accent);
    flex: none;
    /* a quiet heartbeat: the page is alive, not "available" */
    animation: breathe 3.6s ease-in-out infinite;
  }

  @keyframes breathe {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.45; transform: scale(0.82); }
  }

  @media (prefers-reduced-motion: reduce) {
    .dot { animation: none; }
  }

  .contact {
    list-style: none;
    padding: 0;
    margin-block-start: var(--s2);
    display: flex;
    flex-wrap: wrap;
    gap: var(--s1) var(--s4);
  }

  .work {
    padding-block-end: var(--s8);
  }

  .all-link {
    margin-block-start: var(--s4);
  }

  .all-link a {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    transition: opacity 0.2s var(--ease-out);
  }

  .all-link a:hover {
    opacity: 0.7;
  }

  .about {
    padding-block: var(--s12);
    border-top: var(--hairline);
  }

  .contact-section {
    padding-block: var(--s8) var(--s16);
  }

  .contact-lead {
    color: var(--muted);
    margin-block-end: var(--s2);
  }

  .contact-big {
    font-size: var(--text-2xl);
    font-weight: var(--weight-semibold);
    letter-spacing: -0.02em;
    overflow-wrap: anywhere;
  }

  .contact-big a {
    color: var(--ink);
    transition: color 0.2s var(--ease-out);
  }

  .contact-big a:hover {
    color: var(--accent);
  }
</style>
