---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { formatDate, isoDate } from '../../lib/format';

const showDrafts = import.meta.env.DEV;
const posts = (await getCollection('blog', ({ data }) => showDrafts || !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Writing" description="Short articles on software engineering.">
  <section class="section pad">
    <SectionHeading index="01" title="Writing" count={posts.length} />
    {
      posts.length === 0 ? (
        <p class="empty mono-label">Writing coming soon. Subscribe via <a href="/rss.xml">RSS</a> to catch the first post.</p>
      ) : (
        <ul class="posts">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}`} class="post-link">
                <time class="mono-label" datetime={isoDate(post.data.pubDate)}>
                  {formatDate(post.data.pubDate)}
                </time>
                <span class="body">
                  <span class="title">
                    {post.data.title}
                    {post.data.draft && <span class="mono-label draft-flag"> [draft]</span>}
                  </span>
                  <span class="description">{post.data.description}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>

<style>
  .empty {
    border: var(--hairline);
    padding: var(--s4);
  }

  .posts {
    list-style: none;
    padding: 0;
    border-top: var(--hairline);
  }

  .post-link {
    display: grid;
    grid-template-columns: 10ch 1fr;
    gap: var(--s3);
    align-items: baseline;
    padding: var(--s3) var(--s2);
    border-bottom: var(--hairline);
    text-decoration: none;
  }

  .post-link:hover,
  .post-link:focus-visible {
    background: var(--ink);
    color: var(--paper);
  }

  .title {
    display: block;
    font-size: var(--text-lg);
    font-weight: 750;
    line-height: 1.1;
  }

  .draft-flag {
    color: var(--accent);
  }

  .post-link:hover .draft-flag {
    color: var(--paper);
  }

  .description {
    display: block;
    margin-block-start: var(--s1);
    max-width: var(--measure);
  }

  @media (max-width: 45rem) {
    .post-link {
      grid-template-columns: 1fr;
      gap: var(--s1);
    }
  }
</style>
