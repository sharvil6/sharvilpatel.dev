---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { formatDate, isoDate } from '../../lib/format';

const showDrafts = import.meta.env.DEV;
const posts = (await getCollection('blog', ({ data }) => showDrafts || !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Writing" description="Short articles on software engineering.">
  <section class="section pad reveal">
    <SectionHeading index="01" title="Writing" count={posts.length} />
    {
      posts.length === 0 ? (
        <p class="empty mono-label">Writing coming soon. Check back for the first post.</p>
      ) : (
        <ul class="posts">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}`} class="post-link">
                <time class="mono-label" datetime={isoDate(post.data.pubDate)}>
                  {formatDate(post.data.pubDate)}
                </time>
                <span class="body">
                  <span class="title">
                    {post.data.title}
                    {post.data.draft && <span class="mono-label draft-flag"> [draft]</span>}
                    <span class="go" aria-hidden="true">&rarr;</span>
                  </span>
                  <span class="description">{post.data.description}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>

<style>
  .empty {
    color: var(--muted);
    padding-block: var(--s4);
  }

  .empty a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .posts {
    list-style: none;
    padding: 0;
  }

  .post-link {
    display: grid;
    grid-template-columns: 10ch 1fr;
    gap: var(--s2) var(--s3);
    align-items: baseline;
    padding-block: var(--s4);
    border-top: var(--hairline);
  }

  /* The section heading already draws a rule beneath it, so the first row's
     top border would double it up. */
  .posts li:first-child .post-link {
    border-top: 0;
  }

  .post-link time {
    color: var(--faint);
  }

  .title {
    display: block;
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    line-height: 1.2;
    transition: color 0.2s var(--ease-out);
  }

  .post-link:hover .title,
  .post-link:focus-visible .title {
    color: var(--accent);
  }

  .go {
    display: inline-block;
    margin-inline-start: 0.4em;
    color: var(--accent);
    opacity: 0;
    transform: translateX(-0.25em);
    transition: opacity 0.25s var(--ease-out), transform 0.25s var(--ease-out);
  }

  .post-link:hover .go,
  .post-link:focus-visible .go {
    opacity: 1;
    transform: translateX(0);
  }

  .draft-flag {
    color: var(--accent);
  }

  .description {
    display: block;
    margin-block-start: var(--s1);
    max-width: var(--measure);
    color: var(--muted);
  }

  @media (max-width: 45rem) {
    .post-link {
      grid-template-columns: 1fr;
      gap: var(--s1);
    }
  }
</style>
