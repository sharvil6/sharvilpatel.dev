---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';

// Placeholder resume content — replace every entry with the real record.
const experience = [
  {
    company: 'DELL',
    title: 'Director - Applied AI',
    range: '2026 — Present',
    location: 'Austin, TX',
    bullets: [
      'Building an AI orchestration platform on a custom agent harness',
      'Started the Applied AI organization, operating like a startup within an enterprise framework'
    ],
  },
  {
    company: 'DELL',
    title: 'Senior Engineering Manager - Dell Pro AI Studio',
    range: '2024 — 2026',
    location: 'Austin, TX',
    bullets: [
      'Drove Dell Pro AI Studio from POC to product launch in just 6 months, leading a global cross-functional team to deliver a first of its kind local AI inference developer framework for Dell AI PCs.',
      'Balanced strategic leadership with hands-on building - defined MVP scope, made tradeoff and prioritization decisions, and maintained direct involvement in design and implementation by writing code, fixing bugs, and triaging issues alongside developers.',
      'Served as the voice of the product to executives and partners (marketing, sales, support, CTO); featured at Dell Tech World as a flagship AI initiative.',
      'Scaled and mentored a team of engineers including new grads and interns, fostering a culture of rapid iteration, technical rigor, and customer focus - building a startup-style "build and iterate" culture inside a Fortune 500.'
    ],
  },
    {
    company: 'DELL',
    title: 'Engineering Manager - Dell Trusted Device',
    range: '2021 — 2024',
    location: 'Austin, TX',
    bullets: [
      'Led a cross-functional team delivering first cloud-based supply chain verification product, enabling customers to validate device integrity upon delivery and creating a recurring revenue stream and a first to market differentiator.',
      'Owned full lifecycle delivery - balancing roadmap strategy with hands-on design and technical reviews',
      'Parterned with product and customers to translate business needs into technical requirements, directly shaping roadmap priorities and security feature development',
    ],
  },
    {
    company: 'DELL',
    title: 'Senior Software Engineer - Firmware Security Solutions',
    range: '2019 — 2021',
    location: 'Austin, TX',
    bullets: [
      'Spearheaded a complete overhaul of BIOS / Firmware code signing infrastructure, developing signing tools and strengthening CI/CD pipelines to reduce release risk and improve resilence of security updates',
    ],
  },
    {
    company: 'DELL',
    title: 'Software Engineer - Firmware Security',
    range: '2017 — 2019',
    location: 'Austin, TX',
    bullets: [
      'Led a team of 5 engineers hardening a substantial portion of Dell BIOS code to support Intel Runtime BIOS Resilience and Microsoft SystemGuard; ultimately leading to Intel showcasing the Dell Latitude 7400 at Computex, calling it "the latest in commercial system design"',
    ],
  },
];

const beyondWork = [
  'Certified Information Systems Security Professional (CISSP), September 2021',
  'Achieved rank of Eagle Scout, March 2012',
  'Developed a rudimentary computer vision system to improve medication adherence',
  'On a quest to visit all 63 U.S. national parks.',
];

const education = {
  school: 'University of Michigan',
  degree: 'B.S Computer Engineering, Minor in Business',
  range: '2013 — 2017',
};
---

<BaseLayout title="Resume" description="Resume of Sharvil Patel, software engineer.">
  <div class="pad">
    <header class="resume-header">
      <div>
        <h1>Sharvil Patel</h1>
        <p class="mono-label contact-strip">
          <a href="mailto:sharvilpatel95@gmail.com">sharvilpatel95@gmail.com</a> &middot;
          <a href="https://github.com/sharvil6">github.com/sharvil6</a> &middot;
          sharvilpatel.dev
        </p>
      </div>
      <a class="download mono-label no-print" href="/resume/sharvil-patel-resume.pdf" download>
        Download PDF &darr;
      </a>
    </header>

    <section class="section">
      <SectionHeading index="01" title="Experience" />
      {
        experience.map((job) => (
          <article class="job">
            <div class="job-head">
              <h3>{job.title} &middot; {job.company}</h3>
              <p class="mono-label">{job.range} &middot; {job.location}</p>
            </div>
            <ul>
              {job.bullets.map((line) => (
                <li>{line}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </section>

    <section class="section">
      <SectionHeading index="04" title="Education" />
      <div class="job-head">
        <h3>{education.degree} &middot; {education.school}</h3>
        <p class="mono-label">{education.range}</p>
      </div>
    </section>

    <section class="section">
      <SectionHeading index="02" title="Projects" />
      <p class="prose">
        Selected personal projects with full writeups:
        <a href="/projects/ai-orchestration-platform">AI Orchestration Platform</a>,
        <a href="/projects/hestia-recipe-share">Hestia</a>, and
        <a href="/projects/ynab-tracking-account">YNAB Tracking Accounts</a>.
      </p>
    </section>

    <section class="section">
      <SectionHeading index="03" title="Beyond Work" />
      <ul class="prose beyond-list">
        {beyondWork.map((item) => <li>{item}</li>)}
      </ul>
    </section>


  </div>
</BaseLayout>

<style>
  .resume-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: var(--s3);
    padding-block: var(--s8) var(--s4);
  }

  h1 {
    font-size: var(--text-2xl);
  }

  .contact-strip {
    margin-block-start: var(--s1);
  }

  .download {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    border: var(--hairline);
    border-color: color-mix(in oklch, var(--accent) 40%, var(--line));
    padding: var(--s1) var(--s3);
    border-radius: 4px;
    transition: background 0.2s var(--ease-out);
  }

  .download:hover {
    background: color-mix(in oklch, var(--accent) 10%, transparent);
  }

  .section {
    padding-block: var(--s4) var(--s6);
  }

  .job + .job {
    margin-block-start: var(--s4);
    border-top: var(--hairline);
    padding-block-start: var(--s4);
  }

  .job-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--s1) var(--s3);
  }

  h3 {
    font-size: var(--text-lg);
  }

  .job ul {
    margin-block-start: var(--s2);
    padding-inline-start: 1.25em;
    max-width: var(--measure);
  }

  .job li + li {
    margin-block-start: var(--s1);
  }

  .beyond-list {
    padding-inline-start: 1.25em;
    max-width: var(--measure);
  }

  .beyond-list li + li {
    margin-block-start: var(--s1);
  }
</style>
